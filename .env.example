# Core
OPENAI_API_KEY=
JARVIS_ENV=development
JARVIS_MAIN_MODEL=gpt-5.4
JARVIS_FAST_MODEL=gpt-5.4-mini
JARVIS_REALTIME_MODEL=gpt-realtime-mini
JARVIS_HISTORY_LIMIT=12

# Memory
JARVIS_MEMORY_BACKEND=local
JARVIS_DATA_DIR=./data
JARVIS_STORAGE_BACKEND=sqlite
JARVIS_DATABASE_PATH=./data/jarvis.db
JARVIS_LOG_LEVEL=INFO
JARVIS_AUTH_REQUIRED=false
JARVIS_AUTH_TOKEN_TTL_HOURS=12
JARVIS_AUTH_LOGIN_WINDOW_MINUTES=15
JARVIS_AUTH_LOGIN_MAX_FAILURES=5
JARVIS_AUTH_LOGIN_LOCK_MINUTES=15
JARVIS_AUTH_PASSWORD_MIN_LENGTH=12
JARVIS_MFA_ENCRYPTION_KEY=
JARVIS_SECRET_VAULT_KEY=
JARVIS_HSTS_ENABLED=false
JARVIS_KNOWLEDGE_MAX_CHUNKS=3
JARVIS_KNOWLEDGE_CHUNK_SIZE=900
JARVIS_KNOWLEDGE_CHUNK_OVERLAP=120
JARVIS_EMBEDDING_MODEL=text-embedding-3-small
JARVIS_EMBEDDING_DIMENSIONS=256
JARVIS_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
JARVIS_TTS_MODEL=gpt-4o-mini-tts
JARVIS_TTS_VOICE=alloy
JARVIS_REALTIME_VOICE=marin

# Threat intel / CVE enrichment
JARVIS_NVD_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
JARVIS_NVD_API_KEY=
JARVIS_HTTP_TIMEOUT_SECONDS=20

# Read-only external connectors
JARVIS_GITHUB_API_BASE_URL=https://api.github.com
JARVIS_GITHUB_TOKEN=
JARVIS_GOOGLE_DRIVE_API_BASE_URL=https://www.googleapis.com/drive/v3
JARVIS_GOOGLE_DRIVE_ACCESS_TOKEN=
JARVIS_JIRA_BASE_URL=
JARVIS_JIRA_EMAIL=
JARVIS_JIRA_API_TOKEN=
JARVIS_ENTRA_ID_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
JARVIS_ENTRA_ID_ACCESS_TOKEN=
JARVIS_DEFENDER_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
JARVIS_DEFENDER_ACCESS_TOKEN=
JARVIS_SENTINEL_API_BASE_URL=https://api.loganalytics.azure.com/v1
JARVIS_SENTINEL_WORKSPACE_ID=
JARVIS_SENTINEL_ACCESS_TOKEN=

# App
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8000
